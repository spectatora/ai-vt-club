---
/**
 * HomeCard — featured-image card used in the homepage post grid.
 *
 * Shows a hero image (or generated gradient placeholder), a coloured
 * category pill, the post title, and a "date · reading time" meta row.
 */
import type { CollectionEntry } from "astro:content";
import { getPostUrl } from "@/utils/getPostPaths";
import { slugifyStr } from "@/utils/slugify";
import dayjs from "dayjs";

type Props = CollectionEntry<"posts"> & { index?: number };
const { id, data, filePath, index = 0 } = Astro.props;
const { title, description, tags, pubDatetime, ogImage } = data;
const postUrl = getPostUrl(id, filePath, Astro.currentLocale);

/* Category from first tag, formatted upper-case */
const categoryRaw = tags?.[0] ?? "тема";
const category = categoryRaw.toUpperCase();

/* Category palette — keeps the badge family on-brand */
const palettes: Record<string, { bg: string; text: string }> = {
  default:    { bg: "#4C1D95", text: "#FFFFFF" }, // deep purple
  ресурси:    { bg: "#B08D56", text: "#1A1530" }, // gold
  новини:     { bg: "#5B2EB8", text: "#FFFFFF" },
  бизнес:     { bg: "#3B0F7A", text: "#FFFFFF" },
};
const palette = palettes[categoryRaw.toLowerCase()] ?? palettes.default;

/* Date formatting: 15 май 2024 */
const bgMonths = ["янт.", "фев.", "март", "апр.", "май", "юни", "юли", "авг.", "септ.", "окт.", "ноем.", "дек."];
const d = dayjs(pubDatetime);
const formattedDate = `${d.date()} ${bgMonths[d.month()]} ${d.year()}`;

/* Reading time — rough estimate (~220 wpm) from description length × 8 */
const approxWords = Math.max(200, (description?.length ?? 0) * 8);
const readingMinutes = Math.max(2, Math.round(approxWords / 220));

/* Image src resolution — string ogImage or a generated placeholder */
type OgImg = string | { src?: string } | undefined;
const og = ogImage as OgImg;
const ogSrc: string | null =
  typeof og === "string" ? og :
  og && typeof og === "object" && typeof og.src === "string" ? og.src :
  null;

/* Gradient placeholders rotate so the grid feels alive even without per-post images */
const placeholders = [
  "linear-gradient(135deg, #2D1B69 0%, #5B2EB8 55%, #7C3AED 100%)",
  "linear-gradient(135deg, #4C1D95 0%, #7C3AED 50%, #A78BFA 100%)",
  "linear-gradient(135deg, #1A0F45 0%, #2D1B69 50%, #B08D56 110%)",
  "linear-gradient(135deg, #5B2EB8 0%, #9D5CFF 60%, #E8C07A 100%)",
];
const placeholderBg = placeholders[index % placeholders.length];
---

<article class="home-card group">
  <a href={postUrl} class="home-card-link" aria-label={title}>
    <div class="home-card-media">
      {ogSrc ? (
        <img src={ogSrc} alt={title} loading="lazy" decoding="async" />
      ) : (
        <div class="home-card-placeholder" style={`background: ${placeholderBg};`} aria-hidden="true">
          <svg viewBox="0 0 120 120" class="home-card-placeholder-svg" aria-hidden="true">
            <defs>
              <linearGradient id={`hc-${id}-g`} x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#E8C07A" stop-opacity="0.95"/>
                <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0.6"/>
              </linearGradient>
            </defs>
            <g fill="none" stroke={`url(#hc-${id}-g)`} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.85">
              <path d="M60 22 L84 36 V70 L60 84 L36 70 V36 Z" />
              <rect x="46" y="46" width="28" height="28" rx="3" fill={`url(#hc-${id}-g)`} opacity="0.18" />
              <text x="60" y="65" text-anchor="middle" font-size="14" font-weight="700" fill="#FFFFFF" stroke="none" font-family="ui-sans-serif, system-ui">AI</text>
              <path d="M22 60 H36 M84 60 H98 M60 12 V22 M60 84 V96" />
              <circle cx="22" cy="60" r="2" fill="#FFFFFF" stroke="none" opacity="0.7"/>
              <circle cx="98" cy="60" r="2" fill="#FFFFFF" stroke="none" opacity="0.7"/>
              <circle cx="60" cy="12" r="2" fill="#FFFFFF" stroke="none" opacity="0.7"/>
              <circle cx="60" cy="96" r="2" fill="#FFFFFF" stroke="none" opacity="0.7"/>
            </g>
          </svg>
        </div>
      )}
    </div>

    <div class="home-card-body">
      <span class="home-card-badge" style={`background: ${palette.bg}; color: ${palette.text};`}>
        {category}
      </span>

      <h3 class="home-card-title" transition:name={slugifyStr(title.replaceAll(".", "-"))}>
        {title}
      </h3>

      <div class="home-card-meta">
        <time datetime={pubDatetime.toISOString()}>{formattedDate}</time>
        <span class="home-card-dot" aria-hidden="true">•</span>
        <span>{readingMinutes} мин. четене</span>
      </div>
    </div>
  </a>
</article>

<style>
  .home-card {
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    transition:
      transform    0.3s var(--ease-spring),
      border-color 0.3s var(--ease-smooth),
      box-shadow   0.3s var(--ease-smooth);
    box-shadow: var(--card-shadow);
    height: 100%;
    display: flex;
  }
  .home-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--accent) 35%, transparent);
    box-shadow: var(--card-shadow-hover);
  }

  .home-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    width: 100%;
    color: inherit;
  }

  .home-card-media {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--surface-high);
  }
  .home-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    transition: transform 0.5s var(--ease-smooth);
  }
  .home-card:hover .home-card-media img {
    transform: scale(1.04);
  }

  .home-card-placeholder {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .home-card-placeholder::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 22% 18%, rgba(255, 255, 255, 0.18) 0%, transparent 38%),
      radial-gradient(circle at 78% 82%, rgba(232, 192, 122, 0.22) 0%, transparent 40%);
  }
  .home-card-placeholder-svg {
    position: relative;
    width: 58%;
    height: auto;
    transition: transform 0.6s var(--ease-spring);
  }
  .home-card:hover .home-card-placeholder-svg {
    transform: scale(1.05) rotate(-2deg);
  }

  .home-card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: 1.1rem 1.1rem 1.25rem;
  }

  .home-card-badge {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    padding: 0.32rem 0.7rem;
    border-radius: 6px;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    line-height: 1;
  }

  .home-card-title {
    font-size: 1.0625rem;
    font-weight: 700;
    line-height: 1.32;
    letter-spacing: -0.01em;
    color: var(--foreground);
    transition: color 0.25s var(--ease-smooth);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .home-card:hover .home-card-title {
    color: var(--accent);
  }

  .home-card-meta {
    margin-top: auto;
    padding-top: 0.6rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.74rem;
    color: var(--muted-foreground);
    border-top: 1px dashed var(--border);
  }
  .home-card-dot {
    color: var(--accent);
    opacity: 0.7;
  }

  @media (prefers-reduced-motion: reduce) {
    .home-card, .home-card-media img, .home-card-placeholder-svg, .home-card-title {
      transition: none !important;
    }
  }
</style>
