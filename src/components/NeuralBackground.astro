---
/**
 * NeuralBackground — full-viewport ambient neural-net layer behind all content.
 *
 * Layers (bottom → top):
 *   1. Soft radial warmth (depth)
 *   2. Faint connection lines crossing the viewport
 *   3. Ambient twinkling stars filling empty space
 *   4. Cluster nodes (input / hidden) pulsing slowly
 *   5. Focal cores with concentric ring ripples + halos
 *
 * The viewBox is 1600×1000 with `xMidYMid slice` so the network fills the
 * viewport at any aspect ratio. Focal nodes are placed in the page margins
 * (outside the max-w-3xl reading column) so the brightest features land
 * beside the text, never behind it.
 *
 * Opacity stays low — the brain is always thinking, never shouting.
 */

type Pt = { x: number; y: number; r: number; d?: number };
type Edge = { a: Pt; b: Pt; d?: number };

// ── Focal nodes (large "thinking" cores) ─────────
const focals: Pt[] = [
  { x:  170, y: 260, r: 14, d: 0.0 },   // upper-left
  { x: 1430, y: 720, r: 16, d: 1.2 },   // lower-right
  { x: 1380, y: 180, r: 10, d: 2.4 },   // upper-right
  { x:  220, y: 820, r: 12, d: 3.0 },   // lower-left
];

// ── Cluster nodes ────────────────────────────────
const clusters: Pt[] = [
  // left column (feeds upper-left focal)
  { x:  40, y:  80, r: 4, d: 0.1 },
  { x:  40, y: 180, r: 5, d: 0.3 },
  { x:  40, y: 300, r: 4, d: 0.5 },
  { x:  40, y: 420, r: 5, d: 0.7 },
  { x:  40, y: 540, r: 4, d: 0.9 },
  { x: 100, y: 140, r: 3, d: 1.1 },
  { x: 110, y: 360, r: 3, d: 1.3 },
  // right column (feeds lower-right focal)
  { x: 1560, y: 480, r: 5, d: 0.2 },
  { x: 1560, y: 600, r: 4, d: 0.4 },
  { x: 1560, y: 720, r: 5, d: 0.6 },
  { x: 1560, y: 840, r: 4, d: 0.8 },
  { x: 1500, y: 560, r: 3, d: 1.0 },
  { x: 1500, y: 780, r: 3, d: 1.2 },
  // around upper-right
  { x: 1560, y:  80, r: 3, d: 0.5 },
  { x: 1560, y: 220, r: 4, d: 0.7 },
  { x: 1490, y: 130, r: 3, d: 0.9 },
  // around lower-left
  { x:  40, y: 740, r: 3, d: 0.6 },
  { x:  40, y: 880, r: 4, d: 0.8 },
  { x: 110, y: 800, r: 3, d: 1.0 },
  // mid-bridge nodes (sit between focals, well outside reading column)
  { x: 600, y: 500, r: 3, d: 1.5 },
  { x: 820, y: 360, r: 4, d: 1.7 },
  { x: 900, y: 640, r: 3, d: 1.9 },
];

// ── Connections: each cluster → nearest focal, plus secondary ──
const connections: Edge[] = [];
const distSq = (a: Pt, b: Pt) => (a.x - b.x) ** 2 + (a.y - b.y) ** 2;

clusters.forEach((c, i) => {
  const sorted = focals
    .map(f => ({ f, d: distSq(c, f) }))
    .sort((a, b) => a.d - b.d);
  connections.push({ a: c, b: sorted[0].f, d: (c.d ?? 0) + 0.2 });
  if (i % 3 === 0) connections.push({ a: c, b: sorted[1].f, d: (c.d ?? 0) + 0.6 });
});

// Inter-focal connections (long sweeping lines)
for (let i = 0; i < focals.length; i++) {
  for (let j = i + 1; j < focals.length; j++) {
    connections.push({ a: focals[i], b: focals[j], d: 0.8 + (i + j) * 0.3 });
  }
}

// ── Ambient star scatter (deterministic PRNG) ────
const mulberry = (seed: number) => {
  let t = (seed + 0x6d2b79f5) >>> 0;
  return () => {
    t = (t + 0x6d2b79f5) >>> 0;
    let r = Math.imul(t ^ (t >>> 15), t | 1);
    r ^= r + Math.imul(r ^ (r >>> 7), r | 61);
    return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
  };
};
const rng = mulberry(42);
const ambient: Pt[] = Array.from({ length: 95 }, () => ({
  x: Math.round(rng() * 1600),
  y: Math.round(rng() * 1000),
  r: 0.7 + rng() * 1.4,
  d: rng() * 6,
}));
---

<div class="neural-bg" aria-hidden="true">
  <svg
    viewBox="0 0 1600 1000"
    preserveAspectRatio="xMidYMid slice"
    class="neural-svg"
  >
    <defs>
      <radialGradient id="nb-halo" cx="50%" cy="50%" r="50%">
        <stop offset="0%"   stop-color="var(--accent)" stop-opacity="0.18"/>
        <stop offset="40%"  stop-color="var(--accent)" stop-opacity="0.05"/>
        <stop offset="100%" stop-color="var(--accent)" stop-opacity="0"/>
      </radialGradient>

      <radialGradient id="nb-warm-tl" cx="15%" cy="20%" r="55%">
        <stop offset="0%"   stop-color="#7C3AED" stop-opacity="0.07"/>
        <stop offset="100%" stop-color="#7C3AED" stop-opacity="0"/>
      </radialGradient>

      <radialGradient id="nb-warm-br" cx="85%" cy="80%" r="55%">
        <stop offset="0%"   stop-color="var(--accent)" stop-opacity="0.05"/>
        <stop offset="100%" stop-color="var(--accent)" stop-opacity="0"/>
      </radialGradient>
    </defs>

    {/* Soft warmth */}
    <rect width="1600" height="1000" fill="url(#nb-warm-tl)"/>
    <rect width="1600" height="1000" fill="url(#nb-warm-br)"/>

    {/* Connections */}
    {connections.map(({ a, b, d }) => (
      <line
        x1={a.x} y1={a.y} x2={b.x} y2={b.y}
        class="nb-conn"
        style={`--nb-d:${(d ?? 0).toFixed(2)}s`}
      />
    ))}

    {/* Focal halos */}
    {focals.map(f => (
      <circle
        cx={f.x} cy={f.y} r={f.r * 6}
        fill="url(#nb-halo)"
        class="nb-halo"
        style={`--nb-d:${(f.d ?? 0).toFixed(2)}s`}
      />
    ))}

    {/* Ambient stars */}
    {ambient.map(p => (
      <circle
        cx={p.x} cy={p.y} r={p.r}
        class="nb-star"
        style={`--nb-d:${(p.d ?? 0).toFixed(2)}s`}
      />
    ))}

    {/* Cluster nodes */}
    {clusters.map(c => (
      <circle
        cx={c.x} cy={c.y} r={c.r}
        class="nb-node"
        style={`--nb-d:${(c.d ?? 0).toFixed(2)}s`}
      />
    ))}

    {/* Focal cores + concentric ripples */}
    {focals.map(f => (
      <>
        <circle
          cx={f.x} cy={f.y} r={f.r}
          class="nb-ring"
          style={`--nb-d:${(f.d ?? 0).toFixed(2)}s`}
        />
        <circle
          cx={f.x} cy={f.y} r={f.r}
          class="nb-ring"
          style={`--nb-d:${((f.d ?? 0) + 1.7).toFixed(2)}s`}
        />
        <circle
          cx={f.x} cy={f.y} r={f.r}
          class="nb-core"
          style={`--nb-d:${(f.d ?? 0).toFixed(2)}s`}
        />
      </>
    ))}
  </svg>
</div>

<style>
  .neural-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    user-select: none;
    overflow: hidden;
    contain: strict;
  }

  .neural-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ── Connections ─────────────────────────── */
  .nb-conn {
    stroke: var(--accent);
    stroke-width: 0.6;
    opacity: 0.03;
    animation: nb-conn-flash 9s ease-in-out infinite;
    animation-delay: var(--nb-d, 0s);
  }
  @keyframes nb-conn-flash {
    0%, 100% { opacity: 0.025; }
    50%       { opacity: 0.09;  }
  }

  /* ── Halo behind focal ───────────────────── */
  .nb-halo {
    transform-box: fill-box;
    transform-origin: center;
    opacity: 0.5;
    animation: nb-halo-pulse 7s ease-in-out infinite;
    animation-delay: var(--nb-d, 0s);
  }
  @keyframes nb-halo-pulse {
    0%, 100% { opacity: 0.25; transform: scale(1);    }
    50%       { opacity: 0.45; transform: scale(1.12); }
  }

  /* ── Ambient stars ───────────────────────── */
  .nb-star {
    fill: var(--accent);
    opacity: 0.07;
    animation: nb-star-twinkle 6s ease-in-out infinite;
    animation-delay: var(--nb-d, 0s);
  }
  @keyframes nb-star-twinkle {
    0%, 100% { opacity: 0.04; }
    50%       { opacity: 0.13; }
  }

  /* ── Cluster nodes ───────────────────────── */
  .nb-node {
    fill: var(--accent);
    opacity: 0.16;
    animation: nb-node-pulse 5s ease-in-out infinite;
    animation-delay: var(--nb-d, 0s);
  }
  @keyframes nb-node-pulse {
    0%, 100% { opacity: 0.10; }
    50%       { opacity: 0.28; }
  }

  /* ── Focal core ──────────────────────────── */
  .nb-core {
    fill: var(--accent);
    opacity: 0.35;
    filter: drop-shadow(0 0 4px var(--accent));
    animation: nb-core-glow 4s ease-in-out infinite;
    animation-delay: var(--nb-d, 0s);
  }
  @keyframes nb-core-glow {
    0%, 100% { opacity: 0.28; filter: drop-shadow(0 0 3px var(--accent)); }
    50%       { opacity: 0.5;  filter: drop-shadow(0 0 8px var(--accent)); }
  }

  /* ── Concentric ripple rings around focals ── */
  .nb-ring {
    fill: none;
    stroke: var(--accent);
    stroke-width: 1;
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
    animation: nb-ring-expand 5s ease-out infinite;
    animation-delay: var(--nb-d, 0s);
  }
  @keyframes nb-ring-expand {
    0%   { transform: scale(0.6); opacity: 0.22; }
    80%  { opacity: 0.02; }
    100% { transform: scale(3.0); opacity: 0;    }
  }

  /* ── Theme tuning ────────────────────────── */
  [data-theme="dark"]  .neural-bg { opacity: 0.42; }
  [data-theme="light"] .neural-bg { opacity: 0.22; }

  /* ── Reduced motion ──────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .nb-conn, .nb-halo, .nb-star, .nb-node, .nb-core, .nb-ring {
      animation: none;
    }
    .nb-conn { opacity: 0.05; }
    .nb-halo { opacity: 0.35; }
    .nb-star { opacity: 0.09; }
    .nb-node { opacity: 0.20; }
    .nb-core { opacity: 0.35; }
    .nb-ring { opacity: 0;    }
  }
</style>
