---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import HomeCard from "@/components/HomeCard.astro";
import Divider from "@/components/Divider.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const homePath = getRelativeLocaleUrl(locale, "");

const posts       = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts   = sortedPosts.filter(({ data }) => !data.featured);
const gridPosts = [...featuredPosts, ...recentPosts].slice(0, 4);
---

<Layout>
  <Header />

  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
  >

    <!-- ════════════════════════════════════════
         HERO — wide banner with castle, lion & AI shield
    ════════════════════════════════════════ -->
    <section class="hero-section app-wide">
      <div class="hero-banner">
        <img
          src="/banner-castle.png"
          alt="Велико Търново — Царевец и AI"
          width="1983"
          height="793"
          fetchpriority="high"
          loading="eager"
          class="hero-banner-img"
        />
        <div class="hero-banner-overlay" aria-hidden="true"></div>
        <div class="hero-banner-grain" aria-hidden="true"></div>

        <div class="hero-content">
          <h1 class="hero-title">
            AI&nbsp;за Велико Търново<span class="brand-dot" aria-hidden="true"></span><br/>
            <span class="hero-title-soft">Бъдещето е тук<span class="brand-dot" aria-hidden="true"></span></span>
          </h1>

          <p class="hero-sub">
            Практични идеи, полезни инструменти и реални примери&nbsp;за изкуствен интелект.
          </p>

          <div class="hero-cta-row">
            <a href={getRelativeLocaleUrl(locale, "posts")} class="cta-primary">
              НАУЧИ ПОВЕЧЕ
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M13 6l6 6-6 6"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════
         DUAL FEATURE PANELS
    ════════════════════════════════════════ -->
    <section class="features-section app-wide">
      <div class="features-grid">
        <!-- Dark feature panel — castle + lion silhouette -->
        <a href={getRelativeLocaleUrl(locale, "posts")} class="feature-card feature-dark">
          <div class="feature-content">
            <h2 class="feature-title feature-title-light">
              Знание. Технологии<span class="brand-dot" aria-hidden="true"></span><br/>
              Бъдеще<span class="brand-dot" aria-hidden="true"></span>
            </h2>
            <p class="feature-sub feature-sub-light">
              Блогът за изкуствен интелект<br/>
              и дигитални решения във Велико Търново.
            </p>
            <span class="feature-cta feature-cta-gold">
              РАЗГЛЕДАЙ БЛОГА
            </span>
          </div>
          <div class="feature-art feature-art-dark" aria-hidden="true">
            <!-- Veliko Tarnovo silhouette: Tsarevets hill + Patriarchate church + lion + AI shield -->
            <svg viewBox="0 0 320 240" fill="none" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="fd-stone" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%"   stop-color="#E8C07A" stop-opacity="1"/>
                  <stop offset="60%"  stop-color="#C4974A" stop-opacity="0.95"/>
                  <stop offset="100%" stop-color="#7C3AED" stop-opacity="0.85"/>
                </linearGradient>
                <linearGradient id="fd-tower" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%"   stop-color="#FFE6B8" stop-opacity="1"/>
                  <stop offset="100%" stop-color="#C4974A" stop-opacity="0.9"/>
                </linearGradient>
                <radialGradient id="fd-shield" cx="50%" cy="35%" r="65%">
                  <stop offset="0%"   stop-color="#E8C07A" stop-opacity="1"/>
                  <stop offset="55%"  stop-color="#A78BFA" stop-opacity="0.85"/>
                  <stop offset="100%" stop-color="#5B2EB8" stop-opacity="0.6"/>
                </radialGradient>
              </defs>

              <!-- Constellation -->
              <g fill="#E8C07A">
                <circle cx="34"  cy="34"  r="1.6" opacity="0.9"/>
                <circle cx="62"  cy="22"  r="1.1" opacity="0.85"/>
                <circle cx="98"  cy="42"  r="1.3" opacity="0.9"/>
                <circle cx="48"  cy="68"  r="0.9" opacity="0.7"/>
                <circle cx="138" cy="18"  r="1.0" opacity="0.85"/>
              </g>
              <g stroke="#A78BFA" stroke-width="0.6" opacity="0.4">
                <line x1="34" y1="34" x2="62" y2="22"/>
                <line x1="62" y1="22" x2="98" y2="42"/>
                <line x1="98" y1="42" x2="138" y2="18"/>
                <line x1="34" y1="34" x2="48" y2="68"/>
              </g>

              <!-- Hill base -->
              <path d="M0 230 Q60 200 130 198 Q200 196 320 226 V240 H0 Z" fill="rgba(45, 27, 105, 0.55)"/>
              <path d="M0 240 Q70 218 150 216 Q230 214 320 238 V240 H0 Z" fill="rgba(45, 27, 105, 0.85)"/>

              <!-- Fortress wall (left) with crenellations -->
              <g fill="url(#fd-stone)">
                <path d="M10 210 V172 h6 v-8 h6 v8 h6 v-8 h6 v8 h6 v-8 h6 v8 h6 v38 z"/>
                <!-- Lower side wall -->
                <path d="M50 210 V184 h4 v-6 h4 v6 h4 v-6 h4 v6 h4 v26 z"/>
              </g>

              <!-- Patriarchate church (centre tower) -->
              <g>
                <!-- Main body -->
                <path d="M132 210 V148 h36 v62 z" fill="url(#fd-stone)"/>
                <!-- Side wings -->
                <path d="M118 210 V164 h14 v46 z M168 210 V164 h14 v46 z" fill="url(#fd-stone)" opacity="0.92"/>
                <!-- Tall central tower -->
                <path d="M138 148 V92 l12 -10 l12 10 v56 z" fill="url(#fd-tower)"/>
                <!-- Dome + cross -->
                <path d="M144 92 Q150 70 156 92 Z" fill="#E8C07A"/>
                <line x1="150" y1="74" x2="150" y2="62" stroke="#E8C07A" stroke-width="1.4" stroke-linecap="round"/>
                <line x1="146" y1="68" x2="154" y2="68" stroke="#E8C07A" stroke-width="1.4" stroke-linecap="round"/>
                <!-- Windows -->
                <g fill="#2D1B69" opacity="0.85">
                  <rect x="146" y="118" width="3" height="8" rx="1"/>
                  <rect x="151" y="118" width="3" height="8" rx="1"/>
                  <rect x="124" y="178" width="3" height="6"/>
                  <rect x="173" y="178" width="3" height="6"/>
                  <rect x="143" y="180" width="14" height="20" rx="3"/>
                </g>
                <!-- Smaller side spires -->
                <path d="M108 164 V134 l6 -8 l6 8 v30 z" fill="url(#fd-tower)" opacity="0.95"/>
                <path d="M180 164 V134 l6 -8 l6 8 v30 z" fill="url(#fd-tower)" opacity="0.95"/>
                <circle cx="114" cy="124" r="2" fill="#E8C07A"/>
                <circle cx="186" cy="124" r="2" fill="#E8C07A"/>
              </g>

              <!-- Lion statue (right foreground, profile silhouette like Tsarevets) -->
              <g>
                <!-- Plinth -->
                <rect x="206" y="200" width="58" height="30" rx="1.5" fill="url(#fd-stone)" opacity="0.95"/>
                <!-- Front paw / chest base -->
                <path d="M216 200 q0 -10 6 -14 q3 -2 8 -2 v16 z" fill="url(#fd-stone)" opacity="0.98"/>
                <!-- Hind legs -->
                <path d="M250 200 q-2 -14 4 -22 q3 -4 8 -4 v26 z" fill="url(#fd-stone)" opacity="0.95"/>
                <!-- Body (chest + back) -->
                <path d="M222 184 q4 -16 18 -22 q14 -4 28 4 q8 8 8 18 q0 12 -8 16 H222 z" fill="url(#fd-stone)" opacity="0.98"/>
                <!-- Mane (rough, curly outline behind head) -->
                <path d="M236 168 q-12 0 -16 -10 q-4 -12 4 -22 q3 -4 8 -4 q-2 -10 8 -14 q12 -4 18 4 q14 -2 18 8 q12 0 14 12 q2 12 -8 16 q-4 14 -18 14 z" fill="url(#fd-stone)" opacity="0.95"/>
                <!-- Head (snout/muzzle) -->
                <path d="M262 154 q12 0 14 8 q2 6 -4 10 q-2 6 -10 6 q-8 0 -12 -6 q-4 -8 4 -14 q4 -4 8 -4 z" fill="url(#fd-tower)" opacity="0.98"/>
                <!-- Snout tip + jaw -->
                <path d="M274 168 q4 2 4 6 q0 4 -6 4 q-2 -2 -2 -6 z" fill="#2D1B69" opacity="0.45"/>
                <!-- Ears -->
                <path d="M246 144 q-2 -8 2 -10 q4 -2 4 6 z" fill="url(#fd-stone)" opacity="0.95"/>
                <path d="M260 142 q4 -8 8 -6 q4 4 0 10 z" fill="url(#fd-stone)" opacity="0.95"/>
                <!-- Eyes -->
                <circle cx="262" cy="160" r="1.4" fill="#2D1B69"/>
                <circle cx="270" cy="160" r="1.4" fill="#2D1B69"/>
                <!-- Mane texture flecks -->
                <g fill="#2D1B69" opacity="0.35">
                  <circle cx="226" cy="158" r="1"/>
                  <circle cx="224" cy="170" r="0.9"/>
                  <circle cx="234" cy="142" r="0.9"/>
                  <circle cx="246" cy="132" r="0.9"/>
                  <circle cx="276" cy="138" r="0.9"/>
                  <circle cx="288" cy="156" r="1"/>
                  <circle cx="282" cy="170" r="0.9"/>
                </g>
                <!-- Tail curl behind -->
                <path d="M296 196 q10 -10 6 -22 q-3 -6 -8 -4" stroke="url(#fd-stone)" stroke-width="3" stroke-linecap="round" fill="none" opacity="0.9"/>
              </g>

              <!-- AI shield (top right) -->
              <g transform="translate(244 24)">
                <!-- Glow halo -->
                <circle cx="32" cy="38" r="36" fill="#A78BFA" opacity="0.15"/>
                <!-- Shield body -->
                <path d="M4 8 q28 -10 56 0 v28 q0 24 -28 36 q-28 -12 -28 -36 z" fill="url(#fd-shield)" stroke="#E8C07A" stroke-width="1.2"/>
                <!-- Circuit traces radiating out -->
                <g stroke="#A78BFA" stroke-width="0.8" fill="none" stroke-linecap="round">
                  <path d="M-8 22 H0 M0 22 V14 H-6"/>
                  <path d="M-8 38 H4 M-2 38 V46 H-10"/>
                  <path d="M-8 54 H8"/>
                  <path d="M72 22 H64 M64 22 V14 H70"/>
                  <path d="M72 38 H60 M66 38 V46 H74"/>
                  <path d="M72 54 H56"/>
                  <path d="M32 -2 V8 M26 -2 V4 M38 -2 V4"/>
                </g>
                <g fill="#E8C07A" opacity="0.9">
                  <circle cx="-6" cy="14" r="1.2"/>
                  <circle cx="-10" cy="46" r="1.2"/>
                  <circle cx="-8" cy="54" r="1.2"/>
                  <circle cx="70" cy="14" r="1.2"/>
                  <circle cx="74" cy="46" r="1.2"/>
                  <circle cx="72" cy="54" r="1.2"/>
                  <circle cx="26" cy="-2" r="1.2"/>
                  <circle cx="38" cy="-2" r="1.2"/>
                </g>
                <!-- Chip plate -->
                <rect x="18" y="28" width="28" height="22" rx="3" fill="#2D1B69" opacity="0.55"/>
                <text x="32" y="44" text-anchor="middle" font-size="11" font-weight="800" fill="#FFFFFF" font-family="ui-sans-serif, system-ui">AI</text>
              </g>
            </svg>
          </div>
        </a>

        <!-- Light feature panel — AI tools / lightbulb -->
        <a href={getRelativeLocaleUrl(locale, "tags")} class="feature-card feature-light">
          <div class="feature-content">
            <h2 class="feature-title">
              AI инструменти<br/>
              за всеки<span class="brand-dot" aria-hidden="true"></span>
            </h2>
            <p class="feature-sub">
              Открий най-добрите AI инструменти,<br/>
              съвети и трикове за ежедневието и&nbsp;бизнеса.
            </p>
            <span class="feature-cta feature-cta-purple">
              ВИЖ ПОВЕЧЕ
            </span>
          </div>
          <div class="feature-art feature-art-light" aria-hidden="true">
            <!-- Lightbulb 'AI' held by a robotic hand, surrounded by tool icons -->
            <svg viewBox="0 0 320 260" fill="none" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <radialGradient id="fl-glow" cx="50%" cy="45%" r="55%">
                  <stop offset="0%"   stop-color="#FFF0C5" stop-opacity="1"/>
                  <stop offset="40%"  stop-color="#FFE08A" stop-opacity="0.9"/>
                  <stop offset="75%"  stop-color="#E8C07A" stop-opacity="0.55"/>
                  <stop offset="100%" stop-color="#B08D56" stop-opacity="0"/>
                </radialGradient>
                <linearGradient id="fl-hand" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%"   stop-color="#FAF9FD"/>
                  <stop offset="100%" stop-color="#E2DDF2"/>
                </linearGradient>
                <linearGradient id="fl-bulb-glass" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%"   stop-color="#FFE9A8" stop-opacity="0.95"/>
                  <stop offset="100%" stop-color="#E8C07A" stop-opacity="0.85"/>
                </linearGradient>
              </defs>

              <!-- Floating icon chips around the bulb -->
              <g stroke="#4C1D95" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <!-- Chat bubble (top-left) -->
                <g transform="translate(8 16)">
                  <rect x="0" y="0" width="46" height="30" rx="8" fill="#FFFFFF"/>
                  <path d="M14 30 L10 38 L22 30 Z" fill="#FFFFFF" stroke-linejoin="miter"/>
                  <circle cx="14" cy="15" r="1.8" fill="#4C1D95"/>
                  <circle cx="23" cy="15" r="1.8" fill="#4C1D95"/>
                  <circle cx="32" cy="15" r="1.8" fill="#4C1D95"/>
                </g>

                <!-- Cog (top-right) -->
                <g transform="translate(252 14)" stroke-width="1.6">
                  <g>
                    <line x1="22" y1="2"  x2="22" y2="10"/>
                    <line x1="22" y1="34" x2="22" y2="42"/>
                    <line x1="2"  y1="22" x2="10" y2="22"/>
                    <line x1="34" y1="22" x2="42" y2="22"/>
                    <line x1="7.5"  y1="7.5"  x2="13" y2="13"/>
                    <line x1="31" y1="13" x2="36.5"  y2="7.5"/>
                    <line x1="7.5"  y1="36.5" x2="13" y2="31"/>
                    <line x1="31" y1="31" x2="36.5" y2="36.5"/>
                  </g>
                  <circle cx="22" cy="22" r="11" fill="#FFFFFF"/>
                  <circle cx="22" cy="22" r="4"  fill="#B08D56" stroke="#4C1D95" stroke-width="1.2"/>
                </g>

                <!-- Bar chart (middle-left) -->
                <g transform="translate(0 102)">
                  <rect x="0" y="0" width="56" height="44" rx="4" fill="#FFFFFF"/>
                  <line x1="8"  y1="36" x2="50" y2="36"/>
                  <line x1="8"  y1="36" x2="8"  y2="8"/>
                  <rect x="14" y="24" width="6" height="12" fill="#4C1D95" stroke="none"/>
                  <rect x="24" y="18" width="6" height="18" fill="#7C3AED" stroke="none"/>
                  <rect x="34" y="10" width="6" height="26" fill="#B08D56" stroke="none"/>
                  <path d="M14 22 L24 16 L34 10 L44 4" stroke="#B08D56" stroke-width="1.6" fill="none"/>
                  <circle cx="44" cy="4" r="1.6" fill="#B08D56" stroke="none"/>
                </g>

                <!-- Brain (bottom-right) -->
                <g transform="translate(248 168)" stroke-width="1.6">
                  <rect x="6" y="6" width="44" height="50" rx="20" fill="#FFFFFF"/>
                  <path d="M28 12 V52" />
                  <path d="M14 22 q8 4 14 -2 M14 38 q8 4 14 -2 M42 22 q-8 4 -14 -2 M42 38 q-8 4 -14 -2"/>
                  <circle cx="16" cy="32" r="1.8" fill="#4C1D95"/>
                  <circle cx="40" cy="32" r="1.8" fill="#4C1D95"/>
                </g>
              </g>

              <!-- Sparkles -->
              <g fill="#B08D56" opacity="0.85">
                <circle cx="74"  cy="62"  r="1.4"/>
                <circle cx="218" cy="76"  r="1.0"/>
                <circle cx="86"  cy="178" r="1.2"/>
                <circle cx="232" cy="158" r="1.4"/>
              </g>

              <!-- Centre: glow halo behind bulb -->
              <circle cx="160" cy="118" r="92" fill="url(#fl-glow)" opacity="0.85"/>

              <!-- Lightbulb (centre) -->
              <g transform="translate(120 42)">
                <!-- Glass envelope -->
                <path d="M40 24 q0 -24 40 -24 q40 0 40 24 q0 22 -14 38 v14 h-52 v-14 q-14 -16 -14 -38 z" fill="url(#fl-bulb-glass)" stroke="#4C1D95" stroke-width="1.4"/>
                <!-- Highlight glint -->
                <path d="M58 18 q-6 6 -6 18" stroke="#FFFFFF" stroke-width="2.4" stroke-linecap="round" opacity="0.7" fill="none"/>
                <!-- AI text -->
                <text x="80" y="72" text-anchor="middle" font-size="34" font-weight="800" fill="#4C1D95" font-family="ui-sans-serif, system-ui">AI</text>
                <!-- Bulb base (threads) -->
                <g fill="#4C1D95">
                  <rect x="60" y="78" width="40" height="6" rx="1.5"/>
                  <rect x="62" y="86" width="36" height="4" rx="1"/>
                  <rect x="64" y="92" width="32" height="4" rx="1"/>
                  <path d="M72 100 h16 v6 q0 4 -4 4 h-8 q-4 0 -4 -4 z"/>
                </g>
              </g>

              <!-- Robot hand cradling the bulb -->
              <g>
                <!-- Forearm -->
                <path d="M58 252 q-2 -24 14 -34 h176 q16 10 14 34 z" fill="url(#fl-hand)" stroke="#4C1D95" stroke-width="1.4"/>
                <!-- Palm -->
                <path d="M76 218 q4 -14 22 -16 h124 q18 2 22 16 v10 H76 z" fill="url(#fl-hand)" stroke="#4C1D95" stroke-width="1.4"/>
                <!-- Wrist seam + joints -->
                <line x1="84" y1="222" x2="236" y2="222" stroke="#4C1D95" stroke-width="0.8" opacity="0.55"/>
                <line x1="84" y1="240" x2="236" y2="240" stroke="#4C1D95" stroke-width="0.8" opacity="0.55"/>
                <circle cx="90"  cy="231" r="2.2" fill="#B08D56" stroke="#4C1D95" stroke-width="0.8"/>
                <circle cx="230" cy="231" r="2.2" fill="#B08D56" stroke="#4C1D95" stroke-width="0.8"/>
                <!-- Fingers cradling -->
                <g fill="url(#fl-hand)" stroke="#4C1D95" stroke-width="1.4">
                  <path d="M96 218 q-6 -22 4 -38 q6 -10 16 -8 v18 q-4 4 -4 12 v16 z"/>
                  <path d="M204 218 q6 -22 -4 -38 q-6 -10 -16 -8 v18 q4 4 4 12 v16 z"/>
                </g>
              </g>
            </svg>
          </div>
        </a>
      </div>
    </section>

    <!-- ════════════════════════════════════════
         LATEST POSTS GRID
    ════════════════════════════════════════ -->
    {gridPosts.length > 0 && (
      <section class="posts-section app-wide">
        <header class="posts-header">
          <h2 class="posts-heading">Последни публикации</h2>
          <div class="posts-heading-underline" aria-hidden="true"></div>
        </header>

        <ul class="posts-grid">
          {gridPosts.map((post, i) => (
            <li class="posts-grid-item" style={`--card-delay:${i * 90}ms`}>
              <HomeCard {...post} index={i} />
            </li>
          ))}
        </ul>

        <div class="posts-cta">
          <a href={getRelativeLocaleUrl(locale, "posts")} class="cta-ghost">
            Виж всички публикации
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6"/>
            </svg>
          </a>
        </div>
      </section>
    )}

    <!-- Decorative AI-chip divider -->
    <div class="app-wide section-divider-wrap">
      <Divider size="lg" />
    </div>

  </main>

  <Footer />
</Layout>

<style>
  /* ════════════════════════════════════════
     HERO BANNER
  ════════════════════════════════════════ */
  .hero-section {
    padding-top: 1.25rem;
    padding-bottom: 1.5rem;
  }
  @media (min-width: 768px) {
    .hero-section { padding-top: 2rem; padding-bottom: 2.5rem; }
  }

  .hero-banner {
    position: relative;
    width: 100%;
    aspect-ratio: 2.5 / 1;
    min-height: 280px;
    border-radius: 22px;
    overflow: hidden;
    isolation: isolate;
    box-shadow:
      0 1px 2px rgba(45, 27, 105, 0.06),
      0 18px 60px -16px rgba(45, 27, 105, 0.30);
  }
  @media (min-width: 1024px) {
    .hero-banner { aspect-ratio: 3 / 1; min-height: 360px; }
  }

  .hero-banner-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center right;
  }

  .hero-banner-overlay {
    position: absolute;
    inset: 0;
    background: var(--hero-overlay);
    z-index: 1;
  }
  @media (max-width: 768px) {
    .hero-banner-overlay {
      background: linear-gradient(
        180deg,
        rgba(20, 12, 60, 0.65) 0%,
        rgba(20, 12, 60, 0.85) 100%
      );
    }
  }
  .hero-banner-grain {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 18% 28%, rgba(124, 58, 237, 0.18) 0%, transparent 60%),
      radial-gradient(circle at 6% 100%, rgba(45, 27, 105, 0.30) 0%, transparent 55%);
    z-index: 2;
    mix-blend-mode: multiply;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
    padding: 1.75rem 1.5rem;
    max-width: 38rem;
  }
  @media (min-width: 640px) {
    .hero-content { padding: 2.5rem 3rem; gap: 1.25rem; }
  }
  @media (min-width: 1024px) {
    .hero-content { padding: 3rem 4rem; }
  }

  .hero-title {
    font-size: clamp(1.5rem, 4.4vw, 2.85rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.025em;
    color: #FFFFFF;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.35);
  }
  .hero-title-soft {
    font-weight: 700;
    color: #E2D9FF;
  }

  .hero-sub {
